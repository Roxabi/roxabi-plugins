{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 120,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.js",
      "!node_modules",
      "!plugins/web-intel/.venv",
      "!plugins/dev-core/cli/__tests__",
      "!.cache"
    ]
  },
  "overrides": []
}
